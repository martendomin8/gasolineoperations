# ============================================================
# NominationEngine — Environment Variables
# ============================================================
# Copy this file to .env.local for local development
# Set these as Vercel environment variables for production

# ── Database (Neon) ─────────────────────────────────────────
# Use the "pooled" connection string from Neon dashboard for production
# (enables PgBouncer connection pooling for serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/nominationengine?sslmode=require

# Optional: separate superuser connection for auth (bypasses RLS)
# Use the "direct" (non-pooled) connection string from Neon
DATABASE_URL_AUTH=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/nominationengine?sslmode=require

# ── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# Set to your production domain on Vercel
NEXTAUTH_URL=https://your-app.vercel.app

# ── AI Parsing (Anthropic) ──────────────────────────────────
# Get from https://console.anthropic.com
# If missing, deal parser falls back to regex demo mode
ANTHROPIC_API_KEY=sk-ant-...

# ── Email Sending (Resend) ──────────────────────────────────
# Get from https://resend.com — free tier: 3000 emails/month
# If missing, email send is logged to console (demo mode)
RESEND_API_KEY=re_...
# The "from" address (must be a verified domain in Resend)
EMAIL_FROM=NomEngine <noreply@yourdomain.com>

# ── Sedna Integration (optional) ────────────────────────────
# Leave blank to skip Sedna — emails sent via Resend instead
SEDNA_API_KEY=
SEDNA_API_BASE_URL=https://api.sedna.com/v1
