{
  "_meta": {
    "description": "Operational zones — piracy/war risk areas (visible overlays), forbidden routing zones (hidden from non-dev users, block Dijkstra), and navigable whitelists (override GSHHG land-safety check in narrow straits). Source of truth for both the frontend risk overlay and the Python routing pipeline.",
    "source_of_truth": "Edited via the Fleet dev-tools Zone Editor. Committed to git so every deployment ships identical zones.",
    "schema_version": 1,
    "fields": {
      "id": "kebab-case unique identifier",
      "label": "display name in tooltip / editor list",
      "category": "piracy | war | tension | forbidden | navigable — controls default color + description tone",
      "visible": "true = rendered on map (risk overlay toggle); false = only shown in dev-tools",
      "blocksRouting": "true = Dijkstra refuses arcs whose sample points fall inside; false = purely informational",
      "navigable": "true = passes the land-safety check inside this polygon even when GSHHG reports land (narrow straits, canals)",
      "polygon": "ordered [lat, lon] vertices — closing vertex is implicit",
      "note": "operator-facing description",
      "since": "when the zone became active / was identified"
    }
  },
